# Google Maps API key — enable these APIs in Google Cloud Console:
#   Maps JavaScript API, Distance Matrix API, Places API
GOOGLE_MAPS_API_KEY=your_key_here

PORT=3000

# Auth — required in production (at least 16 random characters)
JWT_SECRET=change_me_to_a_long_random_string

# SQLite database directory (default: ./data). Use a persistent volume on Railway.
# DATA_DIR=/data
